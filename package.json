{
	"name": "short-giraffe-theme",
	"displayName": "Short Giraffe Theme",
	"description": "A dark theme with carefully picked colors",
	"author": "kumamaki <8641684+kumamaki@users.noreply.github.com>",
	"version": "2.2.1",
	"publisher": "kumamaki",
	"license": "WTFPL",
	"preview": true,
	"icon": "logo-simple.png",
	"engines": {
		"vscode": "^1.59.0"
	},
	"categories": [
		"Themes"
	],
	"contributes": {
		"themes": [
			{
				"label": "Short Giraffe",
				"uiTheme": "vs-dark",
				"path": "./vscode/theme.json"
			},
			{
				"label": "Short Giraffe Darker",
				"uiTheme": "vs-dark",
				"path": "./vscode/theme-darker.json"
			},
			{
				"label": "Short Giraffe High Contrast",
				"uiTheme": "hc-black",
				"path": "./vscode/theme-high-contrast.json"
			}
		]
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/kumamaki/Short-Giraffe"
	},
	"scripts": {
		"generate": "bun src/generate.ts",
		"generate:watch": "bun --watch src/generate.ts",
		"typecheck": "bun tsc --noEmit",
		"typecheck:watch": "bun tsc --noEmit --watch",
		"build": "bun run typecheck && bun run generate"
	},
	"devDependencies": {
		"@types/bun": "^1.3.4",
		"typescript": "^5"
	},
	"packageManager": "pnpm@9.12.3"
}
